{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-circle-social",
  "title": "Circle Admin",
  "version": "0.2.0",
  "description": "Friendly light-mode admin aesthetic: white card surfaces on a soft grey canvas (#f8f9fc), blue (#3b82f6) and violet (#8b5cf6) dual-accent, system font, 12px rounded cards, hairline borders, subtle shadows, and crisp role/status pills. Archetype = left sidebar (brand mark + context switcher + grouped nav) + sticky topbar + 4 KPI cards + action-queue panel + side panel + area chart + records table, plus matching list, form, and detail screens.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-circle-social",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "light-mode",
    "friendly",
    "blue-violet",
    "dual-accent",
    "sidebar",
    "dashboard",
    "data-dense"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this friendly light-mode admin aesthetic to my domain — white cards on a grey canvas, blue/violet dual-accent, left sidebar with context switcher, 4 KPI cards, action-queue panel, side panel, area chart, and a records table, plus list / form / detail screens.",
        "zh-CN": "将这个友好浅色调管理界面风格应用到我的领域：白色卡片搭配灰色画布，蓝色/紫色双强调色，左侧边栏含上下文切换器，4 个 KPI 卡片，操作队列面板，侧边面板，面积图，以及记录表格，并配套列表 / 表单 / 详情页面。"
      },
      "exampleOutputs": [
        {
          "path": "./example.html",
          "title": "Circle Admin — Dashboard"
        },
        {
          "path": "./assets/dashboard.html",
          "title": "Circle Admin — Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "Circle Admin — List"
        },
        {
          "path": "./assets/form.html",
          "title": "Circle Admin — Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Circle Admin — Detail"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "laws-of-ux"
      ],
      "assets": [
        "./example.html",
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "admin-dashboards",
      "note": "original archetype; no third-party template reproduced"
    }
  }
}
