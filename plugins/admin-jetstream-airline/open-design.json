{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-jetstream-airline",
  "title": "Jetstream Admin",
  "version": "0.2.0",
  "description": "Dark navy precision-control admin aesthetic: near-black canvas (#0a0f1a), indigo + sky-blue dual-accent on a cool-blue neutral ramp, slim 48px navbar with entity-switcher pill, icon-only rail, 4 KPI tiles, live-status board with state pills, inline SVG bar chart, full-width records table with filter chips, and a resource side panel. Built for high-density operational consoles with a cool, precision-control feel.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-jetstream-airline",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "dark-mode",
    "dark-navy",
    "indigo-sky",
    "dual-accent",
    "status-board",
    "control-console",
    "dense-data"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this dark navy precision-control admin aesthetic to my domain",
        "zh-CN": "使用这个插件：Apply this dark navy precision-control admin aesthetic to my domain"
      },
      "exampleOutputs": [
        {
          "path": "./example.html",
          "title": "Dashboard"
        },
        {
          "path": "./assets/dashboard.html",
          "title": "Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "Records List"
        },
        {
          "path": "./assets/form.html",
          "title": "New Record Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Record Detail"
        },
        {
          "path": "./assets/template.html",
          "title": "Screen Template"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "laws-of-ux"
      ],
      "assets": [
        "./example.html",
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "admin-dashboards",
      "note": "original archetype; no third-party template reproduced"
    }
  }
}
