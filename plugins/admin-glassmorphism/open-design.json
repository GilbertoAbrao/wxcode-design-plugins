{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-glassmorphism",
  "title": "Glassmorphism Admin",
  "version": "0.2.0",
  "description": "Dark-mode admin built on frosted glass panels — translucent surfaces (rgba white 4%) with backdrop-filter blur over a soft aurora gradient background, cyan accent (#4dd0e1), hairline white-alpha borders, soft inner glow on actives. Archetype = glass sidebar + glass topbar + 4 KPI tiles with sparklines + 2-column main grid (area chart / top-N list) + full-width glass records table with tinted status capsules, plus matching list, form, and detail screens.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-glassmorphism",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "glassmorphism",
    "dark-mode",
    "frosted-glass",
    "aurora-gradient",
    "backdrop-blur",
    "modern",
    "cyan-accent"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this frosted-glass admin aesthetic to my domain — aurora gradient canvas, glass sidebar, glass topbar, 4 KPI tiles with sparklines, area chart + top-N list grid, full-width records table with tinted status capsules, plus list, form, and detail screens.",
        "zh-CN": "将这个毛玻璃风格应用到我的领域：极光渐变背景、玻璃侧栏、玻璃顶栏、4 个带迷你折线图的 KPI 卡片、面积图 + 排行列表的双列布局、带状态标签的全宽记录表格，以及配套的列表、表单和详情页面。"
      },
      "exampleOutputs": [
        {
          "path": "./example.html",
          "title": "Glassmorphism Admin — Dashboard"
        },
        {
          "path": "./assets/dashboard.html",
          "title": "Glassmorphism Admin — Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "Glassmorphism Admin — List"
        },
        {
          "path": "./assets/form.html",
          "title": "Glassmorphism Admin — Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Glassmorphism Admin — Detail"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "typographic-rhythm"
      ],
      "assets": [
        "./example.html",
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "admin-dashboards",
      "note": "original archetype; no third-party template reproduced"
    }
  }
}
