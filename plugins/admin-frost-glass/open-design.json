{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-frost-glass",
  "title": "Frost Glass Admin",
  "version": "0.2.0",
  "description": "Glassmorphism admin aesthetic: deep indigo-violet-teal radial gradient canvas, frosted translucent panels (backdrop-filter blur, 1px rgba-white borders, soft ambient shadow), cyan (#22d3ee) and violet (#a78bfa) dual-accent system, near-white text on dark surfaces. Archetype = glass sidebar + topbar + 4 KPI tiles with sparklines + area chart with period tabs + alerts side panel + full-width records table with status pills, plus list, form, and detail screens.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-frost-glass",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "glassmorphism",
    "dark-mode",
    "frosted-glass",
    "gradient-canvas",
    "cyan-violet",
    "blur-panel",
    "dark-premium",
    "status-board"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this glassmorphism admin aesthetic to my domain — deep gradient canvas, frosted glass panels, cyan and violet accents, 4 KPI tiles with sparklines, area chart with period tabs, live alerts side panel, dense records table with status pills, plus list, form, and detail screens.",
        "zh-CN": "将这个玻璃拟态管理风格应用到我的领域：深色渐变背景、磨砂玻璃面板、青色与紫色双强调色、4 个带迷你折线的 KPI 卡片、带时段选项卡的面积图、实时告警侧栏、密集的带状态标签的记录表，以及列表、表单和详情页面。"
      },
      "exampleOutputs": [
        {
          "path": "./example.html",
          "title": "Frost Glass Admin — Dashboard"
        },
        {
          "path": "./assets/dashboard.html",
          "title": "Frost Glass Admin — Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "Frost Glass Admin — List"
        },
        {
          "path": "./assets/form.html",
          "title": "Frost Glass Admin — Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Frost Glass Admin — Detail"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "laws-of-ux"
      ],
      "assets": [
        "./example.html",
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "admin-dashboards",
      "note": "original archetype; no third-party template reproduced"
    }
  }
}
