{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-saas-bestseller",
  "title": "SaaS Admin Bestseller",
  "version": "0.2.0",
  "description": "Polished light-mode admin aesthetic: near-white canvas (#f5f7fa), white card surfaces, indigo accent (#5369f8), soft card shadows, 12px radius, system font stack. Archetype = collapsible 256px grouped-nav sidebar + breadcrumb topbar + greeting strip + 4 stat tiles with sparklines + 8/4 mid-grid (area chart / activity feed) + full-width records table, plus matching list, form, and detail screens.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-saas-bestseller",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "light-mode",
    "clean-cards",
    "indigo-accent",
    "soft-shadow",
    "sidebar-nav",
    "polished"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this polished light-mode admin aesthetic to my domain — near-white canvas, indigo accent, grouped-nav sidebar, breadcrumb topbar, 4 stat tiles with sparklines, an area-chart card with an activity feed, and a dense records table, plus list, form, and detail screens.",
        "zh-CN": "将这个精致的浅色管理界面风格应用到我的领域：近白色画布、靛蓝强调色、分组导航侧边栏、面包屑顶栏、4个带迷你图的统计卡片、带活动信息流的面积图卡片和密集的记录表格，以及列表、表单和详情页面。"
      },
      "exampleOutputs": [
        {
          "path": "./assets/dashboard.html",
          "title": "SaaS Admin — Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "SaaS Admin — List"
        },
        {
          "path": "./assets/form.html",
          "title": "SaaS Admin — Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "SaaS Admin — Detail"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "laws-of-ux"
      ],
      "assets": [
        "./example.html",
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ]
  }
}
