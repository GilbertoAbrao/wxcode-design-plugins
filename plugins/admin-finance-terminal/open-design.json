{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-finance-terminal",
  "title": "Terminal Admin",
  "version": "0.2.0",
  "description": "Pure-black monospace terminal aesthetic: page canvas #0E0E0E, raised panels #1A1A1A, amber accent (#FFB800), monospace type throughout, zero-radius sharp edges, and 1px grid-line borders. Archetype = 32px status bar + 24px ticker strip + 200px F-key module rail + 3-column body (rail | center 2-row | right 2-row) + 36px command-line footer. Built for high-density real-time consoles that must scan 50+ data points without scrolling.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-finance-terminal",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "dark-mode",
    "monospace",
    "amber-accent",
    "dense-data",
    "zero-radius",
    "ticker-strip",
    "terminal-aesthetic",
    "enterprise"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this black monospace terminal aesthetic to my domain — pure-black canvas, amber accent, monospace type throughout, ticker strip, F-key module rail, dense data table, summary block with sparkline, gauge constraints, and a command-line footer.",
        "zh-CN": "将这个黑色等宽终端风格应用到我的领域：纯黑底色、琥珀强调色、全等宽字体、行情滚动条、F 键模块侧栏、密集数据表格、带折线图的摘要区块、约束仪表盘，以及命令行底栏。"
      },
      "exampleOutputs": [
        {
          "path": "./example.html",
          "title": "Terminal Admin — Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "Terminal Admin — List"
        },
        {
          "path": "./assets/form.html",
          "title": "Terminal Admin — Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Terminal Admin — Detail"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "state-coverage"
      ],
      "assets": [
        "./example.html",
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "admin-dashboards",
      "note": "original archetype; no third-party template reproduced"
    }
  }
}
