{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-dense-grid",
  "title": "Dense Grid Admin",
  "version": "0.2.0",
  "description": "Maximum-information-density dark-mode admin aesthetic: near-black canvas (#0c0f12), blue accent (#3b82f6), green/red directional signals, all-monospace tabular figures on a 4-px grid. Archetype = slim toolbar + 2-column main grid: primary data table + secondary mini-table (left), sparkline strip + depth panel + stats strip (right). Every pixel earns its place.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-dense-grid",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "dense",
    "dark-mode",
    "monospace",
    "compact",
    "high-density",
    "tabular",
    "data-grid",
    "blue-accent"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this high-density dark-mode terminal aesthetic to my domain",
        "zh-CN": "将这种高密度深色模式终端风格应用到我的领域"
      },
      "exampleOutputs": [
        {
          "path": "./assets/dashboard.html",
          "title": "Dense Grid Admin — Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "Dense Grid Admin — List"
        },
        {
          "path": "./assets/form.html",
          "title": "Dense Grid Admin — Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Dense Grid Admin — Detail"
        },
        {
          "path": "./assets/template.html",
          "title": "Dense Grid Admin — Template Seed"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "laws-of-ux"
      ],
      "assets": [
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "admin-dashboards",
      "note": "original archetype; no third-party template reproduced"
    }
  }
}
