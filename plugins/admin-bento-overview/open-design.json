{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-bento-overview",
  "title": "Bento Overview",
  "version": "0.2.0",
  "description": "Light-mode bento-grid admin aesthetic: neutral canvas (#f6f7f9), white tiles, hairline borders, and a multi-accent palette of indigo, teal, amber, and rose. Archetype = sticky header with period chips + full-width asymmetric CSS grid of hero, chart, KPI, activity feed, donut, mini-table, and status tiles — no sidebar. Matching list, form, and detail screens complete the set.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-bento-overview",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "bento-grid",
    "light-mode",
    "multi-accent",
    "asymmetric-layout",
    "indigo-accent",
    "teal-accent",
    "data-tiles",
    "enterprise"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this light bento-grid admin aesthetic to my domain — neutral canvas, multi-accent tiles, hero metric, area chart, KPI pills, activity feed, donut chart, mini-table, and status tile, plus list, form, and detail screens.",
        "zh-CN": "将这个浅色宾托网格管理界面风格应用到我的领域：中性底色、多强调色磁贴、英雄指标、面积图、KPI 胶囊、活动流、环形图、迷你表格和状态磁贴，以及列表、表单和详情页面。"
      },
      "exampleOutputs": [
        {
          "path": "./example.html",
          "title": "Bento Overview — Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "Bento Overview — List"
        },
        {
          "path": "./assets/form.html",
          "title": "Bento Overview — Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Bento Overview — Detail"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "laws-of-ux"
      ],
      "assets": [
        "./example.html",
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "admin-dashboards",
      "note": "original archetype; no third-party template reproduced"
    }
  }
}
