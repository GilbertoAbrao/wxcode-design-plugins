{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-quartz-lms",
  "title": "Quartz Admin",
  "version": "0.2.0",
  "description": "Friendly light-mode admin aesthetic: near-white canvas (#faf9fc), purple accent (#9333ea), white cards with soft shadow, left sidebar with entity switcher and grouped nav, top bar with search and period selector, 4 KPI tiles, dual-line area chart, upcoming-items side panel, and records table with category tag pills and progress bars.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-quartz-lms",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "light-mode",
    "purple-accent",
    "soft-card",
    "category-tags",
    "friendly-admin"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this friendly light-mode purple admin aesthetic to my domain",
        "zh-CN": "将这个友好的浅色模式紫色管理界面风格应用到我的领域"
      },
      "exampleOutputs": [
        {
          "path": "./assets/dashboard.html",
          "title": "Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "Records List"
        },
        {
          "path": "./assets/form.html",
          "title": "New Record Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Record Detail"
        },
        {
          "path": "./assets/template.html",
          "title": "Template Seed"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "laws-of-ux"
      ],
      "assets": [
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "themeforest-admin-templates",
      "note": "category design-language reference only; original implementation"
    }
  }
}
