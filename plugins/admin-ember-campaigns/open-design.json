{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-ember-campaigns",
  "title": "Ember Admin",
  "version": "0.2.0",
  "description": "Vibrant-but-clean light-mode admin aesthetic: white/#fafafa canvas, rose-pink accent (#e11d48) on a slate neutral ramp, secondary indigo for chart contrast, #ececf0 borders. Left sidebar with brand icon + nav sections + footer cluster, sticky topbar with search + date-range + bell + avatar, 4 KPI cards with inline SVG sparklines and delta chips, a 7/5 split middle row (multi-series SVG line chart + conversion funnel bars), and a full-width records table with typed channel chips and status pills.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-ember-campaigns",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "web",
    "admin",
    "light-mode",
    "rose-accent",
    "vibrant",
    "analytics",
    "sidebar",
    "sparkline",
    "funnel-chart",
    "multi-series-chart"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "analytics",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this vibrant rose-accent light-mode admin aesthetic to my domain",
        "zh-CN": "使用这个充满活力的玫瑰色调浅色模式管理界面风格来构建我的应用"
      },
      "exampleOutputs": [
        {
          "path": "./assets/dashboard.html",
          "title": "Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "Records List"
        },
        {
          "path": "./assets/form.html",
          "title": "New Record Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Record Detail"
        },
        {
          "path": "./assets/template.html",
          "title": "Screen Seed Template"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "laws-of-ux"
      ],
      "assets": [
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "themeforest-admin-templates",
      "note": "category design-language reference only; original implementation"
    }
  }
}
