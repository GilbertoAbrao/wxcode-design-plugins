{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-verdant-clinic",
  "title": "Verdant Admin",
  "version": "0.2.0",
  "description": "Calm light-mode admin aesthetic: near-white #f7faf9 canvas, white cards with emerald-to-teal accent (#10b981 / #0d9488), slate text hierarchy, and tri-tone status pills. Archetype = left sidebar (entity-switcher + sectioned nav + user chip) + 60px topbar + 4 KPI cards with sparklines + 2-column main grid (schedule board + chart panel) + full-width records table, plus matching list, form, and detail screens.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-verdant-clinic",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "light-mode",
    "emerald-teal",
    "calm",
    "status-pills",
    "sidebar-nav",
    "data-table"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this calm emerald-teal light-mode admin aesthetic to my domain — left sidebar with entity-switcher and sectioned nav, 60px topbar with search and date badge, 4 KPI cards with sparklines, a 2-column main grid (schedule board + chart panel), and a full-width records table, plus list, form, and detail screens.",
        "zh-CN": "将这个平静的祖母绿-青色浅色管理风格应用到我的领域：左侧边栏含实体切换和分组导航、60px顶栏含搜索和日期标签、4个KPI卡片含迷你图、两列主网格（时间表+图表面板）、全宽记录表，以及配套列表、表单和详情页面。"
      },
      "exampleOutputs": [
        {
          "path": "./example.html",
          "title": "Verdant Admin — Dashboard"
        },
        {
          "path": "./assets/dashboard.html",
          "title": "Verdant Admin — Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "Verdant Admin — List"
        },
        {
          "path": "./assets/form.html",
          "title": "Verdant Admin — Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Verdant Admin — Detail"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "laws-of-ux"
      ],
      "assets": [
        "./example.html",
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "themeforest-admin-templates",
      "note": "category design-language reference only; original implementation"
    }
  }
}
