{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-harbor-banking",
  "title": "Harbor Admin",
  "version": "0.2.0",
  "description": "Light-mode card admin aesthetic: white surfaces on a slate-tinted canvas (#f6f8fb), navy-to-blue primary gradient (#1e3a8a → #2563eb), teal secondary (#0d9488), 10px card radius, hairline borders, and subtle shadows. Archetype = narrow dark-navy entity-list sidebar + sticky topbar with search pill + hero row (stylized card SVG + 3 KPI tiles) + 2-column content area (donut chart + dense records table left; quick-action panel + scheduled items right). Optimised for high-trust, card-centric operations consoles.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-harbor-banking",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "light-mode",
    "navy-blue",
    "teal",
    "card-centric",
    "trustworthy",
    "white-surface",
    "sidebar-admin",
    "donut-chart",
    "kpi-tiles",
    "records-table"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this light navy-teal card admin aesthetic to my domain",
        "zh-CN": "将这个 light navy-teal 卡片风格的 admin 外观应用到我的领域"
      },
      "exampleOutputs": [
        {
          "path": "./assets/dashboard.html",
          "title": "Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "Records List"
        },
        {
          "path": "./assets/form.html",
          "title": "New Transfer Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Transaction Detail"
        },
        {
          "path": "./assets/template.html",
          "title": "Seed Template"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "laws-of-ux"
      ],
      "assets": [
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "themeforest-admin-templates",
      "note": "category design-language reference only; original implementation"
    }
  }
}
