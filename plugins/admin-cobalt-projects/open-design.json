{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-cobalt-projects",
  "title": "Cobalt Admin",
  "version": "0.2.0",
  "description": "Light-mode admin aesthetic: near-white canvas, cobalt-blue accent (#2563eb), white card surfaces with soft borders and subtle shadow, chromatic category chips, compact priority and status pills, sparkline KPI cards, Gantt strip, and sidebar entity list. Card-forward, clarity-first operational console skin.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-cobalt-projects",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "light-mode",
    "cobalt",
    "card-forward",
    "sidebar-entity-list",
    "gantt-strip",
    "multi-category",
    "clean-cards"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this cobalt light-mode admin aesthetic to my domain",
        "zh-CN": "将这个浅色 Cobalt 管理界面风格应用到我的业务领域"
      },
      "exampleOutputs": [
        {
          "path": "./assets/dashboard.html",
          "title": "Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "List"
        },
        {
          "path": "./assets/form.html",
          "title": "Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Detail"
        },
        {
          "path": "./assets/template.html",
          "title": "Template seed"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "laws-of-ux"
      ],
      "assets": [
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "themeforest-admin-templates",
      "note": "category design-language reference only; original implementation"
    }
  }
}
