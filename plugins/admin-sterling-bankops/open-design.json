{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-sterling-bankops",
  "title": "Sterling Admin",
  "version": "0.2.0",
  "description": "Sober light-mode admin aesthetic: white card surfaces on a cool-grey page, slate-blue structural chrome with an emerald positive accent, grouped-nav sidebar with entity switcher, white topbar with period tabs, 4 KPI cards, action-queue panel with inline approve/reject, severity-feed side panel, records table with status pills, and an inline bar chart. Built for clarity and institutional trust.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-sterling-bankops",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "light-mode",
    "slate-blue",
    "emerald",
    "sober",
    "institutional",
    "trust",
    "approval-queue",
    "severity-feed",
    "bar-chart",
    "dense-table"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this sober light-mode admin aesthetic to my domain",
        "zh-CN": "使用这个插件完成以下任务：Apply this sober light-mode admin aesthetic to my domain"
      },
      "exampleOutputs": [
        {
          "path": "./assets/dashboard.html",
          "title": "Sterling Admin — Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "Sterling Admin — Records List"
        },
        {
          "path": "./assets/form.html",
          "title": "Sterling Admin — New Request Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Sterling Admin — Request Detail"
        },
        {
          "path": "./assets/template.html",
          "title": "Sterling Admin — Seed Template"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "laws-of-ux"
      ],
      "assets": [
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "admin-dashboards",
      "note": "original archetype; no third-party template reproduced"
    }
  }
}
