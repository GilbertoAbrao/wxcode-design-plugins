{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "wxcode-admin-bloom-nonprofit",
  "title": "Bloom Admin",
  "version": "0.2.0",
  "description": "Warm optimistic light-mode admin aesthetic: page canvas #f7fbf9, white cards, emerald accent (#10b981) with coral counter-accent (#fb7185), soft dividers, sidebar-nav layout with entity/scope switcher and program chips, topbar with search and period tabs, 4 KPI cards with sparklines, 2-column mid-row (progress list + segment donut), full-width dual-area trend chart, and dense records table with type pills.",
  "license": "MIT",
  "author": {
    "name": "WXCode",
    "url": "https://github.com/GilbertoAbrao/wxcode-design-plugins"
  },
  "homepage": "https://github.com/GilbertoAbrao/wxcode-design-plugins/tree/main/plugins/admin-bloom-nonprofit",
  "tags": [
    "wxcode-plugin",
    "wxcode",
    "first-party",
    "prototype",
    "operations",
    "web",
    "admin",
    "light-mode",
    "warm-optimistic",
    "emerald",
    "coral",
    "sidebar-nav",
    "progress-bar",
    "donut-chart",
    "area-chart"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "scenario": "operations",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Apply this warm light-mode admin aesthetic to my domain",
        "zh-CN": "使用这个插件完成以下任务：Apply this warm light-mode admin aesthetic to my domain"
      },
      "exampleOutputs": [
        {
          "path": "./assets/dashboard.html",
          "title": "Bloom Admin — Dashboard"
        },
        {
          "path": "./assets/list.html",
          "title": "Bloom Admin — List"
        },
        {
          "path": "./assets/form.html",
          "title": "Bloom Admin — Form"
        },
        {
          "path": "./assets/detail.html",
          "title": "Bloom Admin — Detail"
        },
        {
          "path": "./assets/template.html",
          "title": "Bloom Admin — Shell Seed"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "pixel-discipline",
        "laws-of-ux"
      ],
      "assets": [
        "./assets/dashboard.html",
        "./assets/list.html",
        "./assets/form.html",
        "./assets/detail.html",
        "./assets/template.html",
        "./references/layouts.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "provenance": {
      "category": "admin-dashboards",
      "note": "original archetype; no third-party template reproduced"
    }
  }
}
